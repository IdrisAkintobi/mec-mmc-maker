{
    "name": "mec-mmc-maker",
    "version": "2.3.0",
    "description": "A modern TypeScript library for building MEC and MMC XML files for Amazon Prime",
    "main": "dist/main.js",
    "types": "dist/main.d.ts",
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "rm -rf dist && tsc",
        "test": "jest",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "lint": "eslint src/",
        "lint:fix": "eslint --ext=.ts ./src ./test --fix",
        "prepublishOnly": "npm test && npm run lint",
        "preversion": "npm run lint",
        "version": "npm run format && git add -A src",
        "postversion": "git push && git push --tags"
    },
    "keywords": [
        "amazon-prime",
        "mec",
        "mmc",
        "xml",
        "builder",
        "media",
        "metadata"
    ],
    "author": "Idris Akintobi Adejare <akintobiidris@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IdrisAkintobi/mec-mmc-xml-builder.git"
    },
    "bugs": {
        "url": "https://github.com/IdrisAkintobi/mec-mmc-xml-builder/issues"
    },
    "homepage": "https://github.com/IdrisAkintobi/mec-mmc-xml-builder#readme",
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "eslint": "^9.16.0",
        "globals": "^15.12.0",
        "jest": "^29.7.0",
        "lint-staged": "^15.2.10",
        "prettier": "^3.4.1",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.16.0"
    },
    "dependencies": {
        "fast-xml-parser": "^4.5.0"
    }
}
